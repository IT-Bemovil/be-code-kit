# ═══════════════════════════════════════════════════════
# Bemovil 2.0 Backend — Variables de Entorno
# ═══════════════════════════════════════════════════════
# INSTRUCCIONES:
#   1. Pedi las credenciales de SANDBOX al Tech Lead
#   2. NUNCA uses credenciales de producción en tu máquina local
#   3. NUNCA hagas commit de este archivo (.env está en .gitignore)
# ═══════════════════════════════════════════════════════

# ── General ──────────────────────────────────────────
NODE_ENV=development
DEFAULT_LANG=es
PORT=8200
PORT_WEBSOCKET=4321
# HOST_WEBSOCKET=           # Opcional — dejar vacío para localhost
MULTI_CORE=0
CDN=
EXPIRE_SESSION_MINUTES=0

# ── Database (Write) ─────────────────────────────────
DATABASE_NAME=
DATABASE_WRITE_HOSTNAME=
DATABASE_WRITE_USERNAME=
DATABASE_WRITE_PASSWORD=
DATABASE_PORT=3306

# ── Database (Read Replica) ──────────────────────────
DATABASE_READ_HOSTNAME=
DATABASE_READ_USERNAME=
DATABASE_READ_PASSWORD=

# ── Bepay (Pasarela de pagos) ───────────────────────
BEPAY_BASE_URL=
BEPAY_EMAIL=
BEPAY_PASSWORD=
BEPAY_ACCOUNT_ID=

# ── Hablame (SMS) ───────────────────────────────────
HABLAME_TOKEN=
HABLAME_APIKEY=
HABLAME_ACCOUNT=

# ── AWS S3 ───────────────────────────────────────────
AWS_ACCESS=
AWS_SECRET=
AWS_BUCKET=

# ── Blokay (Reportes) ───────────────────────────────
BLOKAY_PRIVATE_KEY=

# ── Resend (Email transaccional) ────────────────────
RESEND_TOKEN=

